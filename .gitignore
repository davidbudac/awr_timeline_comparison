# Generated AWR reports — keep the directory itself but ignore everything
# inside it (HTML reports, scratch subdirs from experiments, etc.).
/reports/*
!/reports/.gitkeep

# Rendered introduction documents (self-contained HTML with embedded
# screenshots, ~1 MB each) — regenerate from INTRODUCTION.md instead.
/INTRODUCTION.html
/INTRODUCTION.*.html

# OS / editor / tool noise
.DS_Store
.claude/
.conductor/

# Real fleet connection list (aliases + connect strings, possibly with
# plaintext passwords) -- copy fleet.conf.example to fleet.conf and fill it
# in locally; never commit the real one.
/fleet.conf

# AWR Fleet Server (server/) -- local runtime state and local config;
# copy server/server.conf.example to server/server.conf and fill it in.
/server/data/
/server/server.conf

# Python bytecode (server/ app + tests)
__pycache__/
