# Dockerfile.example -- AWR Fleet Server on Oracle Linux 8 slim.
#
# This is a starting point, not a turnkey image: you must supply your own
# Instant Client RPM/zip (licensing) and, typically, a wallet directory
# mounted at runtime. Build from the repo root:
#
#   docker build -f server/deploy/Dockerfile.example -t awr-fleet-server .
#   docker run -d --name awr-fleet-server \
#     -p 127.0.0.1:8765:8765 \
#     -v $(pwd)/server/data:/app/server/data \
#     -v $(pwd)/reports:/app/reports \
#     -v /path/to/wallet:/app/wallet:ro \
#     -v /path/to/fleet.conf:/app/fleet.conf:ro \
#     -e TNS_ADMIN=/app/wallet \
#     awr-fleet-server
#
# The container has NO exposed auth -- keep the published port on
# 127.0.0.1 (as above) or put a reverse proxy in front, same as any other
# deployment of this server.

FROM oraclelinux:8-slim

RUN microdnf install -y bash python3 oracle-instantclient-release-el8 \
    && microdnf install -y oracle-instantclient-basiclite oracle-instantclient-sqlplus \
    && microdnf clean all

ENV LD_LIBRARY_PATH=/usr/lib/oracle/21/client64/lib
ENV PATH="/usr/lib/oracle/21/client64/bin:${PATH}"

WORKDIR /app
COPY . /app

# server/data and reports are meant to be bind-mounted (see docker run
# above) so run history and generated reports survive a container restart.
RUN mkdir -p /app/server/data /app/reports

EXPOSE 8765

CMD ["python3", "server/awrserve.py", "-c", "server/server.conf"]
